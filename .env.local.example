# Resend - Obtené tu API key en https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email desde donde salen los mails (debe ser un dominio verificado en Resend)
# Para pruebas, podés usar: onboarding@resend.dev
RESEND_FROM=SafeContract <noreply@tudominio.com>

# Tu email personal para recibir notificaciones cuando alguien firma
RESEND_NOTIFY_EMAIL=tu@email.com

# URL pública de tu app en Vercel (sin barra final)
NEXT_PUBLIC_BASE_URL=https://tu-proyecto.vercel.app
